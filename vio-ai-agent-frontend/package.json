{
  "name": "vio-ai-agent-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "openapi:fetch": "curl http://localhost:8123/api/v3/api-docs/default -o src/api/openapi.json",
    "openapi:gen": "openapi --input src/api/openapi.json --output src/api/generated --client axios --useOptions --useUnionTypes",
    "openapi:postgen": "node scripts/fix-openapi-gen.js",
    "openapi": "npm run openapi:fetch && npm run openapi:gen && npm run openapi:postgen"
  },
  "dependencies": {
    "@vueuse/head": "^2.0.0",
    "axios": "^1.7.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "openapi-typescript-codegen": "^0.31.0",
    "vite": "^5.4.0"
  }
}
