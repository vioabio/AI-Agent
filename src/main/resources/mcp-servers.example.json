{
  "__comment": "📋 MCP Server 配置模板 — 复制为 mcp-servers.json 后填入真实环境变量值。mcp-servers.json 已在 .gitignore 中，不会被提交。",
  "mcpServers": {
    "amap-maps": {
      "command": "npx.cmd",
      "args": [
        "-y",
        "@amap/amap-maps-mcp-server"
      ],
      "env": {
        "AMAP_MAPS_API_KEY": "${AMAP_MAPS_API_KEY}"
      }
    },
    "vio-image-search-mcp-server": {
      "command": "java",
      "args": [
        "-Dspring.ai.mcp.server.stdio=true",
        "-Dspring.main.web-application-type=none",
        "-Dlogging.pattern.console=",
        "-jar",
        "vio-image-search-mcp-server/target/vio-image-search-mcp-server-0.0.1-SNAPSHOT.jar"
      ],
      "env": {
        "PEXELS_API_KEY": "${PEXELS_API_KEY}"
      }
    }
  }
}
