# ============================================================
# 📋 VIO AI Agent — 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env（.env 已在 .gitignore 中，不会被提交）
#      cp .env.example .env
#   2. 填入你的真实 API Key
#   3. （可选）source .env 或在 IDE 运行配置中设置
# ============================================================

# [必填] 阿里云百炼 DashScope API Key
# 获取地址：https://bailian.console.aliyun.com/
AI_DASHSCOPE_API_KEY=your-dashscope-api-key-here

# [必填] SearchAPI Key（用于联网搜索工具）
# 获取地址：https://www.searchapi.io/
SEARCH_API_KEY=your-searchapi-key-here

# [可选] 高德地图 API Key（用于 MCP 地图服务）
# 获取地址：https://lbs.amap.com/
AMAP_MAPS_API_KEY=your-amap-api-key-here

# [可选] Pexels API Key（用于 MCP 图片搜索服务）
# 获取地址：https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# [可选] PostgreSQL 数据库密码（使用 PGVector 时需要）
DB_PASSWORD=your-db-password-here
